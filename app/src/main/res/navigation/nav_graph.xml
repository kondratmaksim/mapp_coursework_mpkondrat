<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/rollFragment">

    <fragment
        android:id="@+id/rollFragment"
        android:name="com.example.diceroller.ui.RollFragment"
        android:label="Dice Roller"
        tools:layout="@layout/fragment_roll">
        <action
            android:id="@+id/action_rollFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.diceroller.ui.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history" />
</navigation>
